# Mizuki 博客环境变量配置示例
# 复制此文件为 .env 并根据需要填写实际值

# ============================================
# 内容仓库配置 (代码内容分离)
# 项目地址:https://github.com/matsuzaka-yuki/Mizuki-Content
# ============================================

# 是否启用内容分离功能 (true/false)
# true: 启用内容分离,从独立仓库同步内容
# false: 禁用内容分离,使用本地内容 (默认模式)
# 注意: 如果不使用内容分离功能,可以注释掉或设置为 false
ENABLE_CONTENT_SYNC=true

# 内容仓库的 Git URL (仅在 ENABLE_CONTENT_SYNC=true 时需要)
# 支持 HTTPS 和 SSH 两种方式:
# HTTPS: https://github.com/your-username/Mizuki-Content.git
# SSH: git@github.com:your-username/Mizuki-Content.git
CONTENT_REPO_URL=https://github.com/Amiyadesi/sayori-articles.git

# 内容目录路径 (相对于项目根目录)
# 默认: ./content 一般无需改动
CONTENT_DIR=./content

# ============================================
# 自动构建触发配置 (内容仓库更新时)
# ============================================

# 问题: 内容仓库更新不会自动触发代码仓库的部署
# 解决: 配置自动触发机制,推荐使用 Repository Dispatch
# 详见: docs/AUTO_BUILD_TRIGGER.md (5 步快速配置)

# ============================================
# IndexNow SEO 配置
# ============================================

# IndexNow API 密钥，用于向搜索引擎提交 URL 更新
INDEXNOW_KEY=
# 网站主机地址
INDEXNOW_HOST=your.example.com

# ============================================
# B站相关配置 (用于获取观看进度)
# ============================================

# SESSDATA 的获取：
# 1. 登录 bilibili 账号
# 2. 打开浏览器开发者工具（F12 或 Ctrl+Shift+I）
# 3. 找到“应用程序”(app)一栏
# 4. 在请求头中查找 cookie 字段
# 5. 从 cookie 中提取 sessdata 值

# 环境变量名：BILI_SESSDATA     key值：sessdata
BILI_SESSDATA=your_bilibili_sessdata

# ============================================
# GitHub 登录后台配置 (Cloudflare Pages Secrets)
# ============================================

# GitHub OAuth App Client ID
GITHUB_CLIENT_ID=
# GitHub OAuth App Client Secret
GITHUB_CLIENT_SECRET=
# 允许进入后台的 GitHub 登录名
ADMIN_GITHUB_LOGIN=Amiyadesi
# 用于签名 HttpOnly Session Cookie，生产环境请使用高强度随机字符串
SESSION_SECRET=

# ============================================
# 自有访问统计 (Cloudflare Pages Secrets + D1)
# ============================================

# dklyIPdatabase API key，只能作为 Cloudflare Pages Secret 写入，不进前端、不进 Git
DKLY_IPINFO_API_KEY=
# 无 Key 的 IP.SB 位置/ASN 备用源，不提供 VPN/Proxy/Tor 风险判断
IPSB_ENABLED=true
# 用于 HMAC 匿名化 visitor/session/ip hash，生产环境请使用高强度随机字符串
ANALYTICS_HASH_SECRET=
# D1 binding 在 wrangler.toml 中配置为 SAYORI_ANALYTICS_DB

# ============================================
# 私有增长工作台 (Cloudflare Pages Secrets)
# ============================================

# Search Gateway 服务根地址和服务端 API Key
SEARCH_GATEWAY_BASE_URL=https://search.example.com
SEARCH_GATEWAY_API_KEY=

# GeoScore 服务根地址和仅供后台使用的管理 Token
GEOSCORE_API_URL=https://geo-api.example.com
GEOSCORE_ADMIN_TOKEN=

# Umami API 根地址、只读 Token 和网站 ID
UMAMI_API_URL=https://analytics.example.com/api
UMAMI_API_TOKEN=
UMAMI_WEBSITE_ID=

# Google Search Console Service Account 的完整单行 JSON
# Service Account 只需被授予 sc-domain:sayori.org 的查看权限
# Worker 请求的 OAuth scope 固定为 webmasters.readonly
GSC_SERVICE_ACCOUNT_JSON=
GSC_PROPERTY=sc-domain:sayori.org

# 以上数据源均为可选配置，缺失或失败时会显示 not_configured/error，
# 不会伪造 0 分、0 流量或增长建议

# ============================================
# 友链站点截图背景 (Cloudflare Pages Secrets)
# ============================================

# Cloudflare Account ID，用于 /api/screenshot 调用 Browser Rendering REST API
CF_ACCOUNT_ID=
# 只授予 Browser Rendering Edit 权限的 Cloudflare API Token，不进前端、不进 Git
CF_API_TOKEN=
