---
import Comment from "@components/comment/index.astro";
import LastModified from "@components/features/posts/LastModified.astro";
import PostEngagement from "@components/features/posts/PostEngagement.astro";
import PostMeta from "@components/features/posts/PostMeta.astro";
import PostNavigation from "@components/features/posts/PostNavigation.astro";
import RandomPosts from "@components/features/posts/RandomPosts.astro";
import TopicReadingPath from "@components/features/posts/TopicReadingPath.astro";
import ReadingTime from "@components/features/posts/atoms/ReadingTime.astro";
import WordCount from "@components/features/posts/atoms/WordCount.astro";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getPostDisplayTags,
	getSortedPosts,
	isDiaryPost,
} from "@utils/content-utils";
import { resolveLocalImage } from "@utils/local-image";
import { getPostPublicDescription } from "@utils/post-card-content";
import { buildPostPaths } from "@utils/post-url";
import { getFileDirFromPath, removeFileExtension } from "@utils/url-utils";
import { getImage } from "astro:assets";
import { render } from "astro:content";
import {
	licenseConfig,
	randomPostsConfig,
} from "src/config";

import Image from "../../components/atoms/Image/Image.astro";
import Encryptor from "../../components/features/auth/Encryptor.astro";
import AiSummary from "../../components/features/posts/AiSummary.astro";
import { profileConfig, siteConfig } from "../../config";
import { getPublishedTopicForPost } from "../../data/topics";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return buildPostPaths(blogEntries);
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { remarkPluginFrontmatter } = await render(entry);

const publishedTopic = getPublishedTopicForPost(entry.id);
const showRandomPosts = randomPostsConfig.enable;
const footerSuggestionCount =
	Number(Boolean(publishedTopic)) + Number(showRandomPosts);

// Process cover image, for both OG and SharePoster
let ogCoverUrl: string | undefined;
let posterCoverUrl = entry.data.image;

if (entry.data.image) {
	const isLocal = !(
		entry.data.image.startsWith("/") ||
		entry.data.image.startsWith("http") ||
		entry.data.image.startsWith("https") ||
		entry.data.image.startsWith("data:")
	);
	if (isLocal) {
		const basePath = getFileDirFromPath(entry.filePath || "");
		const img = await resolveLocalImage(basePath, entry.data.image);
		if (img) {
			posterCoverUrl = img.src;

			// Resize for OG
			const ogImage = await getImage({
				src: img,
				width: 1200,
				format: "jpeg",
				quality: 80,
			});
			ogCoverUrl = ogImage.src;
		}
	} else if (entry.data.image.startsWith("http")) {
		// Retain the original URL for OG
		ogCoverUrl = entry.data.image;

		// Convert to base64 only for poster
		try {
			const response = await fetch(entry.data.image);
			const arrayBuffer = await response.arrayBuffer();
			const base64 = Buffer.from(arrayBuffer).toString("base64");
			const contentType =
				response.headers.get("content-type") || "image/jpeg";
			posterCoverUrl = `data:${contentType};base64,${base64}`;
		} catch {
			posterCoverUrl = entry.data.image;
		}
	} else {
		ogCoverUrl = entry.data.image; // absolute path like "/images/foo.png"
	}
}

// Process avatar image for SharePoster
let posterAvatarUrl = profileConfig.avatar;
if (profileConfig.avatar) {
	const isLocal = !(
		profileConfig.avatar.startsWith("/") ||
		profileConfig.avatar.startsWith("http") ||
		profileConfig.avatar.startsWith("https") ||
		profileConfig.avatar.startsWith("data:")
	);
	if (isLocal) {
		const img = await resolveLocalImage("", profileConfig.avatar);
		if (img) {
			posterAvatarUrl = img.src;
		}
	}
}

// 判断是否为加密文章
const isEncrypted = !!(entry.data.encrypted && entry.data.password);
const isDiary = isDiaryPost(entry);
const publicDescription = getPostPublicDescription(
	entry.data,
	entry.data.title,
);
const createdDate = entry.data.created || entry.data.published;
const lastEditedDate =
	entry.data.lastEdited || entry.data.updated || entry.data.published;
const updateCount = entry.data.updateCount;
const displayTags = getPostDisplayTags(entry);
const siteUrl = new URL(siteConfig.siteURL).href;
const pageUrl = new URL(Astro.url.pathname, siteConfig.siteURL).toString();
const personId = `${siteUrl}#person`;
const organizationId = `${siteUrl}#organization`;
const blogId = `${siteUrl}#blog`;
const interactionPath = Astro.url.pathname;
const commentPath = `/posts/${removeFileExtension(entry.id)}`;
const canUseAiSummary = !isEncrypted && !isDiary;
const jsonLdImage = new URL(
	ogCoverUrl || "/assets/desktop-banner/1.webp",
	siteConfig.siteURL,
).toString();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"@id": `${pageUrl}#blogposting`,
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": pageUrl,
	},
	headline: entry.data.title,
	description: publicDescription,
	keywords: displayTags,
	author: {
		"@id": personId,
	},
	publisher: {
		"@id": organizationId,
	},
	isPartOf: {
		"@id": blogId,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	dateModified: formatDateToYYYYMMDD(lastEditedDate),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	image: [jsonLdImage],
};
---

<MainGridLayout
	banner={entry.data.image}
	title={entry.data.title}
	description={publicDescription}
	lang={entry.data.lang}
	setOGTypeArticle={true}
	postSlug={entry.id}
	headings={headings}
	coverImage={ogCoverUrl}
	ogImageAlt={entry.data.title}
	publishedTime={entry.data.published}
	modifiedTime={lastEditedDate}
	tags={displayTags}
>
	<script
		is:inline
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify(jsonLd)}
	/>
	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4"
	>
		<div
			id="post-container"
			class:list={[
				"card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full ",
				{
					"paper-note paper-note-lined paper-tape post-paper-note": true,
				},
			]}
			data-post-id={entry.id}
			data-post-alias={entry.data.alias}
			data-content-kind={isDiary ? "diary" : "article"}
			data-effective-read={!isDiary && !isEncrypted ? "true" : "false"}
			data-paper-tear="drop"
			data-paper-restore-scope={`post-${entry.id}`}
		>
			<!-- word count and reading time -->
			<div
				class="flex flex-row text-black/30 dark:text-white/30 gap-5 mb-3 transition onload-animation"
			>
				<div class="flex flex-row items-center">
					<WordCount
						words={remarkPluginFrontmatter.words}
						variant="card"
					/>
				</div>
				<div class="flex flex-row items-center">
					<ReadingTime
						minutes={remarkPluginFrontmatter.minutes}
						variant="card"
					/>
				</div>
			</div>

			<!-- title -->
			<div class="relative onload-animation">
				<div
					data-pagefind-body
					data-pagefind-weight="10"
					data-pagefind-meta="title"
					class="transition w-full block font-bold mb-3
                    text-3xl md:text-[2.25rem]/[2.75rem]
                    text-black/90 dark:text-white/90
                    md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
                    before:absolute before:top-[0.75rem] before:left-[-1.125rem]"
				>
					{entry.data.title}
				</div>
			</div>

			<!-- metadata -->
			<div class="onload-animation">
				<PostMeta
					className="mb-5"
					published={entry.data.published}
					updated={entry.data.updated}
					tags={displayTags}
					category={entry.data.category || undefined}
					id={entry.id}
					showEncrypted={isEncrypted}
					createdDate={createdDate}
					lastEditedDate={lastEditedDate}
					updateCount={updateCount}
					commentPath={commentPath}
					likePath={interactionPath}
					author={entry.data.author || profileConfig.name}
					hideUpdateDate
					hideCategory
					hideTags
					hideHistory
				/>
				{
					(!entry.data.image ||
						(entry.data.image &&
							!siteConfig.showCoverInContent)) && (
						<div class="mt-4 border-[var(--line-divider)] border-dashed border-b-[1px] mb-5" />
					)
				}
			</div>

			<!-- always show cover as long as it has one -->

			{
				entry.data.image && siteConfig.showCoverInContent && (
					<>
						<div class="mt-4" />
						<Image
							id="post-cover"
							src={entry.data.image}
							basePath={getFileDirFromPath(entry.filePath || "")}
							class="mb-8 rounded-xl banner-container onload-animation"
							widths={[640, 1024, 1536, 2048]}
							sizes="(max-width: 768px) 100vw, (max-width: 1200px) 80vw, 1200px"
						/>
					</>
				)
			}

			{canUseAiSummary && (
				<AiSummary summary={entry.data.aiSummary} />
			)}

			{
				isEncrypted ? (
					<Encryptor
						password={entry.data.password}
						hint={entry.data.passwordHint}
					>
						<Markdown class="mb-6 markdown-content onload-animation">
							<Content />
						</Markdown>
					</Encryptor>
				) : (
					<Markdown class="mb-6 markdown-content onload-animation">
						<Content />
					</Markdown>
				)
			}

			<PostEngagement
				class:list={[{ "encrypted-hidden": isEncrypted }]}
				path={interactionPath}
				title={entry.data.title}
				author={entry.data.author || profileConfig.name}
				description={publicDescription}
				pubDate={formatDateToYYYYMMDD(entry.data.published)}
				coverImage={posterCoverUrl}
				url={Astro.url.toString()}
				siteTitle={siteConfig.title}
				avatar={posterAvatarUrl}
				tags={displayTags}
				lastEditedDate={lastEditedDate}
			/>

			{
				licenseConfig.enable && (
					<div
						id="license-component"
						class:list={[
							"encrypted-hidden-wrapper",
							{ "encrypted-hidden": isEncrypted },
						]}
					>
						<License
							title={entry.data.title}
							id={entry.id}
							pubDate={entry.data.published}
							author={entry.data.author}
							sourceLink={entry.data.sourceLink}
							licenseName={entry.data.licenseName}
							licenseUrl={entry.data.licenseUrl}
							class="mb-6 rounded-xl license-container onload-animation"
						/>
					</div>
				)
			}
		</div>
	</div>

	<!-- 评论 -->
	<Comment post={entry} />

	{
		siteConfig.showLastModified && (
			<LastModified
				updatedDate={entry.data.updated || entry.data.published}
			/>
		)
	}

	<PostNavigation
		prevSlug={entry.data.nextSlug}
		prevTitle={entry.data.nextTitle}
		nextSlug={entry.data.prevSlug}
		nextTitle={entry.data.prevTitle}
	/>

	<!-- 人工维护的专题阅读路径与随机探索 -->
	{
		footerSuggestionCount > 0 && (
			<section
				class:list={[
					"post-footer-suggestions mb-4",
					footerSuggestionCount > 1
						? "grid grid-cols-1 xl:grid-cols-2 gap-4"
						: "flex flex-col",
				]}
			>
				{publishedTopic && (
					<TopicReadingPath
						topic={publishedTopic}
						currentPostId={entry.id}
					/>
				)}
				{showRandomPosts && (
					<RandomPosts
						excludeIds={[entry.id]}
						maxCount={randomPostsConfig.maxCount}
					/>
				)}
			</section>
		)
	}
</MainGridLayout>

<style>
	.post-paper-note {
		--paper-line-gap: 33px;
		--paper-line-offset: 16px;
		border-radius: 14px 18px 15px 17px;
		box-shadow:
			0 20px 46px rgba(91, 54, 76, 0.09),
			0 4px 12px rgba(91, 54, 76, 0.06);
		overflow: visible;
	}

	.post-paper-note::before {
		width: clamp(5.5rem, 16%, 8rem);
		height: 1.75rem;
		top: -0.9rem;
		background: linear-gradient(
			135deg,
			rgba(255, 232, 164, 0.62),
			rgba(255, 248, 215, 0.46) 52%,
			rgba(255, 232, 164, 0.62)
		);
		box-shadow:
			0 0.18rem 0.5rem rgba(108, 75, 55, 0.08),
			inset 0 0 0 1px rgba(255, 255, 255, 0.22);
	}

	.post-paper-note :global(.markdown-content blockquote) {
		background: color-mix(in srgb, var(--paper-bg) 64%, white 18%);
	}

	.post-footer-suggestions {
		align-items: stretch;
	}

	.post-footer-suggestions :global(.list-container) {
		height: 100%;
	}

	.post-footer-suggestions :global(.post-list-note) {
		transform: none;
		margin-bottom: 0.75rem;
		padding-top: 0.9rem;
		box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--primary) 8%, transparent);
	}

	.post-footer-suggestions :global(.post-list-note:hover) {
		transform: translateY(-1px);
	}

	@media (min-width: 1280px) {
		.post-footer-suggestions :global(.post-list-note) {
			min-height: 3.75rem;
		}
	}
</style>
