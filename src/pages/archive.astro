---
import ArchivePanel from "@components/features/archive/ArchivePanel.svelte";
import CategoryBar from "@components/features/posts/CategoryBar.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getCategoryList,
	getPostDisplayTags,
	getSortedPostsList,
	getTagList,
	isOrdinaryPublicPost,
} from "@utils/content-utils";

import { siteConfig } from "../config";

const sortedPostsList = (await getSortedPostsList()).filter(
	isOrdinaryPublicPost,
);

const showCategoryBar = siteConfig.postListLayout.categoryBar?.enable ?? false;

// 1. 修复类型兼容性：将 category 的 null 转换为 undefined
const posts = sortedPostsList.map((post) => ({
	id: post.id,
	url: post.url,
	data: {
		title: post.data.title,
		tags: getPostDisplayTags(post),
		category: post.data.category === null ? undefined : post.data.category,
		published: post.data.published,
		alias: post.data.alias,
		permalink: post.data.permalink,
	},
}));

// Keep archive filters useful: singleton tags remain on posts but do not crowd the UI.
const tags = (await getTagList({ minCount: 2, sortBy: "count" })).map(
	(tag) => tag.name,
);
const categories = (await getCategoryList()).map((category) => category.name);
---

<MainGridLayout title={i18n(I18nKey.archive)}>
	{showCategoryBar && <CategoryBar />}
	<!-- 引入右侧边栏布局管理器 -->
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<!-- 修复：补全缺失的 tags 和 categories 属性 -->
	<ArchivePanel
		sortedPosts={posts}
		tags={tags}
		categories={categories}
		client:only="svelte"
	/>
</MainGridLayout>
