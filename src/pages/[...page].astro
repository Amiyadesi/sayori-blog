---
import Pagination from "@components/control/Pagination.astro";
import CategoryBar from "@components/features/posts/CategoryBar.astro";
import PostPage from "@components/features/posts/PostPage.astro";
import RandomPostJump from "@components/features/posts/RandomPostJump.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import type { GetStaticPaths } from "astro";

import { siteConfig } from "../config";
import { PAGE_SIZE } from "../constants/constants";
import { getTopicUrl, topics } from "../data/topics";
import { getSortedPosts, isHomeListPost } from "../utils/content-utils";
import { initPostIdMap } from "../utils/permalink-utils";
import { getPostPublicDescription } from "../utils/post-card-content";
import { getPostUrl } from "../utils/url-utils";

const showCategoryBar = siteConfig.postListLayout.categoryBar?.enable ?? false;

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getSortedPosts();
	// 初始化文章 ID 映射（用于 permalink 功能）
	initPostIdMap(allBlogPosts);
	const homePosts = allBlogPosts.filter(isHomeListPost);
	return paginate(homePosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const { page } = Astro.props;

const len = page.data.length;
const isHomeFirstPage = page.currentPage === 1;
const webmasterTopic = topics.find((topic) => topic.slug === "webmaster");
const homeFaqItems = [
	{
		question: "这个博客主要写什么？",
		answer: "blog.sayori.org 是 Amiya_desi 的个人博客，主要记录服务器探索、Godot 游戏开发、Cloudflare、Docker、Obsidian 写作流、AI 辅助开发、资源整理、项目复盘和日常回声。",
	},
	{
		question: "第一次访问应该从哪里开始？",
		answer: "可以先看最新文章、随机文章入口、个人站长工具箱专题、资源索引、服务器探索和 Godot 相关内容；如果只想了解公开入口，可以回到 sayori.org 查看 GitHub、GeoScore、小白板和留言板。",
	},
	{
		question: "更新节奏和内容边界是什么？",
		answer: "更新节奏跟着真实项目和学习进度走，不承诺固定日更。首页优先展示公开文章、教程、复盘和项目记录；草稿、私人笔记和不适合公开索引的内容不会为了 SEO 被硬塞进来。",
	},
	{
		question: "这里是商业服务站点吗？",
		answer: "不是。这里是个人公开知识和作品记录，不发布公司电话、地址、价格表、本地服务页或商业交付承诺。",
	},
	{
		question: "AI 或搜索引擎可以怎样理解这个站点？",
		answer: "可以把这里理解为 Amiya_desi 的公开博客与项目档案：文章正文、标签、归档、RSS、sitemap 和 llms.txt 用来帮助搜索、实时 AI 引用和公开内容训练抓取理解内容；robots.txt 保持 Google 可解析的标准语法。",
	},
];
const pageDescription = isHomeFirstPage
	? "Amiya的书桌是 Amiya_desi 的个人博客和公开知识入口，记录服务器探索、Godot 游戏开发、Cloudflare、Docker、Obsidian 写作流、AI 辅助开发、资源整理、项目复盘和日常回声。"
	: `${siteConfig.title} - ${siteConfig.subtitle}`;
const pageUrl = new URL(Astro.url.pathname, siteConfig.siteURL).toString();
const siteLanguage = siteConfig.lang.replace("_", "-");
const siteUrl = new URL(siteConfig.siteURL).href;
const personId = `${siteUrl}#person`;
const organizationId = `${siteUrl}#organization`;
const jsonLd: Array<Record<string, unknown>> = [
	{
		"@context": "https://schema.org",
		"@type": "Blog",
		"@id": `${siteUrl}#blog`,
		name: siteConfig.title,
		url: siteUrl,
		description: pageDescription,
		inLanguage: siteLanguage,
		image: new URL("/assets/desktop-banner/1.webp", siteConfig.siteURL)
			.href,
		author: {
			"@id": personId,
		},
		publisher: {
			"@id": organizationId,
		},
	},
	{
		"@context": "https://schema.org",
		"@type": "ItemList",
		"@id": `${pageUrl}#post-list`,
		name: `${siteConfig.title} latest posts`,
		url: pageUrl,
		itemListElement: page.data.map((entry, index) => ({
			"@type": "ListItem",
			position: index + 1,
			url: new URL(getPostUrl(entry), siteConfig.siteURL).href,
			name: entry.data.title,
			description: getPostPublicDescription(entry.data, entry.data.title),
		})),
	},
];

if (isHomeFirstPage) {
	jsonLd.push({
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"@id": `${pageUrl}#faq`,
		name: `${siteConfig.title} 常见问题`,
		url: pageUrl,
		mainEntity: homeFaqItems.map((item) => ({
			"@type": "Question",
			name: item.question,
			acceptedAnswer: {
				"@type": "Answer",
				text: item.answer,
			},
		})),
	});
}
---

<MainGridLayout description={pageDescription}>
	<script
		is:inline
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify(jsonLd)}
	/>
	{showCategoryBar && <CategoryBar />}
	{isHomeFirstPage && <RandomPostJump />}
	<PostPage page={page} />
	{
		isHomeFirstPage && webmasterTopic && (
			<section class="card-base px-5 py-4 mt-4 text-sm leading-7 text-[var(--text-50)]">
				<h2 class="text-base font-semibold text-[var(--text-90)]">
					专题入口
				</h2>
				<a
					class="mt-2 inline-block link text-[var(--primary)] font-semibold"
					href={getTopicUrl(webmasterTopic)}
				>
					{webmasterTopic.title}
				</a>
				<p class="mt-2">{webmasterTopic.description}</p>
			</section>
		)
	}
	{
		isHomeFirstPage && (
			<section class="card-base px-5 py-4 mt-4 text-sm leading-7 text-[var(--text-50)]">
				<details>
					<summary class="cursor-pointer font-semibold text-[var(--text-90)]">
						博客范围与常见问题
					</summary>
					<div class="mt-3 space-y-3">
						<p>
							这里长期记录 Amiya_desi
							的公开知识和作品过程：服务器探索、Godot
							游戏开发、Cloudflare、Docker、Obsidian 写作流、AI
							辅助开发、资源整理、项目复盘和日常回声。主站
							sayori.org
							负责放稳定入口，博客负责放更完整的文章、归档、RSS、随机文章入口和回头看的记录。
							内容会跟着真实项目和学习节奏更新，不会为了填充 GEO
							分数伪造商业服务、价格表或本地公司信息。
						</p>
						{homeFaqItems.map((item) => (
							<article>
								<h2 class="text-base font-semibold text-[var(--text-90)]">
									{item.question}
								</h2>
								<p>{item.answer}</p>
							</article>
						))}
					</div>
				</details>
			</section>
		)
	}
	<Pagination
		class="mx-auto onload-animation"
		page={page}
		style={`animation-delay: calc(var(--content-delay) + ${len * 50}ms)`}
	/>
</MainGridLayout>
