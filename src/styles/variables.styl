/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

:root
  --radius-large 1rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: oklch(0.36 0.008 80) oklch(0.82 0.008 80)
  --page-bg: oklch(0.96 0.006 85) oklch(0.15 0.004 85)
  --card-bg: oklch(0.995 0.003 85) oklch(0.22 0.004 85)
  --card-bg-transparent: rgba(255, 255, 255, 0.8) rgba(23, 23, 23, 0.8)

  --btn-content: oklch(0.42 0.006 85) oklch(0.82 0.006 85)

  --btn-regular-bg: oklch(0.94 0.006 85) oklch(0.30 0.005 85)
  --btn-regular-bg-hover: oklch(0.89 0.008 85) oklch(0.36 0.006 85)
  --btn-regular-bg-active: oklch(0.84 0.01 85) oklch(0.42 0.008 85)
  --btn-strong-bg: oklch(0.42 0.006 85) oklch(0.30 0.005 85)
  --btn-strong-bg-hover: oklch(0.48 0.008 85) oklch(0.36 0.006 85)
  --btn-strong-bg-active: oklch(0.54 0.01 85) oklch(0.42 0.008 85)

  --btn-plain-bg-hover: oklch(0.94 0.006 85) oklch(0.28 0.005 85)
  --btn-plain-bg-active: oklch(0.90 0.008 85) oklch(0.24 0.004 85)

  --btn-card-bg-hover: oklch(0.98 0.003 85) oklch(0.30 0.005 85)
  --btn-card-bg-active: oklch(0.90 0.006 85) oklch(0.35 0.006 85)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.25 0.004 85) oklch(0.88 0.004 85)

  --title-active: oklch(0.36 0.006 85) oklch(0.82 0.006 85)

  --line-divider: black(0.08) white(0.08)

  --line-color: black(0.1) white(0.1)
  --meta-divider: black(0.2) white(0.2)
  --content-meta: black(0.7) white(0.6)

  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)
  --selection-bg: oklch(0.91 0.035 95) oklch(0.40 0.025 95)
  --codeblock-selection: var(--selection-bg)
  --codeblock-bg: oklch(0.97 0.003 85) oklch(0.17 0.004 85)
  --codeblock-topbar-bg: oklch(0.94 0.004 85) oklch(0.12 0.003 85)

  --license-block-bg: black(0.03) var(--codeblock-bg)

  --link-underline: oklch(0.92 0.025 95) oklch(0.40 0.02 95)
  --link-hover: oklch(0.95 0.012 95) oklch(0.40 0.02 95)
  --link-active: oklch(0.89 0.025 95) oklch(0.35 0.02 95)

  --float-panel-bg: oklch(0.995 0.003 85) oklch(0.19 0.004 85)

  --scrollbar-bg-light: black(0.4)
  --scrollbar-bg-hover-light: black(0.5)
  --scrollbar-bg-active-light: black(0.6)

  --scrollbar-bg-dark: white(0.4)
  --scrollbar-bg-hover-dark: white(0.5)
  --scrollbar-bg-active-dark: white(0.6)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.7 0.14 180) oklch(0.75 0.14 180)
  --admonitions-color-note: oklch(0.7 0.14 250) oklch(0.75 0.14 250)
  --admonitions-color-important: oklch(0.7 0.14 310) oklch(0.75 0.14 310)
  --admonitions-color-warning: oklch(0.7 0.14 60) oklch(0.75 0.14 60)
  --admonitions-color-caution: oklch(0.6 0.2 25) oklch(0.65 0.2 25)

  --toc-badge-bg: oklch(0.92 0.025 95) var(--btn-regular-bg)
  --toc-btn-hover: oklch(0.92 0.006 85) oklch(0.22 0.004 85)
  --toc-btn-active: oklch(0.88 0.008 85) oklch(0.25 0.004 85)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.42 0.006 85) oklch(0.78 0.006 85)
})

/* 非全屏壁纸模式下，--card-bg-transparent 应该和 --card-bg 一致（不透明） */
body:not(.wallpaper-transparent)
  --card-bg-transparent: var(--card-bg)

/* 全屏壁纸模式下，--card-bg-transparent 使用真正的半透明值 */
body.wallpaper-transparent
  --card-bg-transparent: rgba(255, 255, 255, 0.8)

:root.dark body.wallpaper-transparent
  --card-bg-transparent: rgba(23, 23, 23, 0.8)
