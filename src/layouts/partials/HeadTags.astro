---
/**
 * HeadTags.astro
 * Head 标签组件 - 包含 SEO meta 标签、主题初始化脚本、CSS 变量等
 *
 * 提取自 Layout.astro 以实现更好的代码组织
 */

import { profileConfig, siteConfig } from "@/config";

import {
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
} from "../../constants/constants";
import { defaultFavicons } from "../../constants/icon";
import type { Favicon } from "../../types/config";
import { url } from "../../utils/url-utils";

interface Props {
	// SEO
	title: string;
	description?: string;

	// Open Graph
	ogImageUrl?: string;
	ogImageAlt?: string;
	setOGTypeArticle?: boolean;
	publishedTime?: Date | string;
	modifiedTime?: Date | string;
	tags?: string[];

	// 配置
	configHue: number;
}

const {
	title,
	description,
	ogImageUrl,
	ogImageAlt,
	setOGTypeArticle = false,
	publishedTime,
	modifiedTime,
	tags = [],
	configHue,
} = Astro.props;

// 关键词
const keywords = siteConfig.keywords;
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteURL).toString();
const ogLocale = siteConfig.lang;
const imageAlt = ogImageAlt || `${title} - ${siteConfig.title}`;
const publishedIso = toIsoDate(publishedTime);
const modifiedIso = toIsoDate(modifiedTime);
const rssUrl = new URL("rss.xml", siteConfig.siteURL).href;
const atomUrl = new URL("atom.xml", siteConfig.siteURL).href;
const sitemapUrl = new URL("sitemap.xml", siteConfig.siteURL).href;
const llmsUrl = new URL("llms.txt", siteConfig.siteURL).href;
const siteUrl = new URL(siteConfig.siteURL).href;
const siteLanguage = siteConfig.lang.replace("_", "-");
const personId = `${siteUrl}#person`;
const organizationId = `${siteUrl}#organization`;
const websiteId = `${siteUrl}#website`;
const blogId = `${siteUrl}#blog`;
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const avatarUrl = profileConfig.avatar
	? new URL(profileConfig.avatar, siteConfig.siteURL).href
	: undefined;
const siteLogo = siteConfig.navbarTitle?.logo || siteConfig.navbarTitle?.icon;
const logoUrl = siteLogo
	? new URL(siteLogo, siteConfig.siteURL).href
	: undefined;
const sameAs = profileConfig.links
	?.map((link) => link.url)
	.filter((link) => typeof link === "string" && link.startsWith("http"));
// 品牌实体（Amiya's Desk）的 Wikidata 条目，用于增强知识图谱关联。
// 注意：这是站点/品牌的 QID，不是个人 QID。
const brandSameAs = [
	"https://www.wikidata.org/wiki/Q140378510",
	...(sameAs ?? []),
];
const personSameAs = [
	"https://www.wikidata.org/wiki/Q140378992",
	...(sameAs ?? []),
];
const breadcrumbItems = [
	{
		"@type": "ListItem",
		position: 1,
		name: siteConfig.title,
		item: siteUrl,
	},
	...(canonicalUrl === siteUrl
		? []
		: [
				{
					"@type": "ListItem",
					position: 2,
					name: title,
					item: canonicalUrl,
				},
			]),
];
const siteJsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"@id": websiteId,
			name: siteConfig.title,
			url: siteUrl,
			description: siteConfig.subtitle,
			inLanguage: siteLanguage,
			publisher: {
				"@id": organizationId,
			},
			creator: {
				"@id": personId,
			},
			about: {
				"@id": personId,
			},
		},
		{
			"@type": "Person",
			"@id": personId,
			name: profileConfig.name,
			url: "https://sayori.org/",
			description: profileConfig.bio,
			...(avatarUrl ? { image: avatarUrl } : {}),
			...(personSameAs.length ? { sameAs: personSameAs } : {}),
		},
		{
			"@type": "Blog",
			"@id": blogId,
			name: siteConfig.title,
			url: siteUrl,
			description: `${siteConfig.title} - ${siteConfig.subtitle}`,
			inLanguage: siteLanguage,
			author: {
				"@id": personId,
			},
			publisher: {
				"@id": organizationId,
			},
			isPartOf: {
				"@id": websiteId,
			},
		},
		{
			"@type": "BreadcrumbList",
			"@id": breadcrumbId,
			itemListElement: breadcrumbItems,
		},
		{
			"@type": ["Organization", "Brand"],
			"@id": organizationId,
			name: siteConfig.title,
			url: siteUrl,
			alternateName: ["Amiya's Desk", "Amiya的书桌"],
			description: `${profileConfig.name} 的个人博客与项目记录站，聚焦游戏开发、服务器折腾、Cloudflare、Obsidian 写作流和 AI 辅助开发复盘。`,
			email: "mailto:me@sayori.org",
			keywords: keywords,
			owner: {
				"@id": personId,
			},
			founder: {
				"@id": personId,
			},
			contactPoint: {
				"@type": "ContactPoint",
				contactType: "public contact",
				email: "me@sayori.org",
				url: "https://sayori.org/",
				availableLanguage: ["zh-CN", "en"],
			},
			...(logoUrl ? { logo: logoUrl } : {}),
			...(brandSameAs.length ? { sameAs: brandSameAs } : {}),
		},
	],
};

// Favicons
const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

function toIsoDate(value?: Date | string) {
	if (!value) {
		return undefined;
	}
	const date = value instanceof Date ? value : new Date(value);
	if (Number.isNaN(date.getTime())) {
		return undefined;
	}
	return date.toISOString();
}
---

<!-- SEO Meta Tags -->
<title>{title}</title>
<meta name="description" content={description || title} />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="theme-color" content={`oklch(0.75 0.14 ${configHue})`} />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-title" content={siteConfig.title} />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
{
	keywords && keywords.length > 0 && (
		<meta name="keywords" content={keywords.join(", ")} />
	)
}
<meta name="author" content={profileConfig.name} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph Tags -->
<meta property="og:site_name" content={siteConfig.title} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description || title} />
{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
{ogImageUrl && <meta property="og:image:width" content="1200" />}
{ogImageUrl && <meta property="og:image:height" content="630" />}
{ogImageUrl && <meta property="og:image:alt" content={imageAlt} />}
<meta property="og:locale" content={ogLocale} />
{
	setOGTypeArticle ? (
		<>
			<meta property="og:type" content="article" />
			{publishedIso && (
				<meta
					property="article:published_time"
					content={publishedIso}
				/>
			)}
			{modifiedIso && (
				<meta property="article:modified_time" content={modifiedIso} />
			)}
			<meta property="article:author" content={profileConfig.name} />
			{tags.map((tag) => (
				<meta property="article:tag" content={tag} />
			))}
		</>
	) : (
		<meta property="og:type" content="website" />
	)
}

<!-- Twitter Card Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description || title} />
{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
{ogImageUrl && <meta name="twitter:image:alt" content={imageAlt} />}

<!-- Feed and crawler discovery -->
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="apple-touch-icon" href="/favicon/amiya-desk-192.png" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={`${siteConfig.title} RSS`}
	href={rssUrl}
/>
<link
	rel="alternate"
	type="application/atom+xml"
	title={`${siteConfig.title} Atom`}
	href={atomUrl}
/>
<link rel="sitemap" href={sitemapUrl} />
<link
	rel="alternate"
	type="text/plain"
	title={`${siteConfig.title} LLM context`}
	href={llmsUrl}
/>
<script
	is:inline
	type="application/ld+json"
	set:html={JSON.stringify(siteJsonLd)}
/>
<!-- Viewport and Generator -->
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />

<!-- Favicons -->
{
	favicons.map((favicon) => (
		<link
			rel="icon"
			href={favicon.src.startsWith("/") ? url(favicon.src) : favicon.src}
			sizes={favicon.sizes}
			media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
		/>
	))
}

<!-- 字体通过构建脚本压缩到 /assets/font/ 目录，此处不再预加载以避免 404 -->
<!-- 字体在构建时通过 scripts/compress-fonts.js 处理并复制到 dist/ -->

<!-- Set the theme before the page is rendered to avoid a flash -->
<script
	is:inline
	define:vars={{
		DEFAULT_THEME,
		LIGHT_MODE,
		DARK_MODE,
		BANNER_HEIGHT_EXTEND: 30,
		configHue,
		pageScaling: siteConfig.pageScaling,
	}}
>
	// Load the theme from local storage
	const theme = localStorage.getItem("theme") || DEFAULT_THEME;
	let isDark = false;
	switch (theme) {
		case LIGHT_MODE:
			document.documentElement.classList.remove("dark");
			isDark = false;
			break;
		case DARK_MODE:
			document.documentElement.classList.add("dark");
			isDark = true;
			break;
	}

	// Set the theme for Expressive Code based on current mode
	const expressiveTheme = isDark ? "github-dark" : "github-light";
	const currentTheme = document.documentElement.getAttribute("data-theme");
	// 只在主题不同时才更新，避免触发不必要的重绘
	if (currentTheme !== expressiveTheme) {
		document.documentElement.setAttribute("data-theme", expressiveTheme);
	}

	// Load the hue from local storage
	const hue = localStorage.getItem("hue") || configHue;
	document.documentElement.style.setProperty("--hue", hue);

	// calculate the --banner-height-extend, which needs to be a multiple of 4 to avoid blurry text
	let offset = Math.floor(window.innerHeight * (BANNER_HEIGHT_EXTEND / 100));
	offset = offset - (offset % 4);
	document.documentElement.style.setProperty(
		"--banner-height-extend",
		`${offset}px`,
	);

	// 自动缩放逻辑 (Moved from MainGridLayout to here for earlier execution)
	(function () {
		if (pageScaling && pageScaling.enable) {
			function adjustPageScale() {
				const isTouch =
					(window.matchMedia &&
						(window.matchMedia("(pointer:coarse)").matches ||
							window.matchMedia("(hover: none)").matches)) ||
					"ontouchstart" in window;
				const isPortrait =
					window.matchMedia &&
					window.matchMedia("(orientation: portrait)").matches;
				const isTabletLike = isTouch || window.innerWidth <= 1280;
				if (isTabletLike || isPortrait) {
					document.documentElement.style.fontSize = "";
					return;
				}
				const targetWidth = pageScaling.targetWidth || 2000;
				const currentWidth = document.documentElement.clientWidth;
				let scale = currentWidth / targetWidth;
				if (scale > 1) {
					scale = 1;
				}
				if (scale < 0.85) {
					scale = 0.85;
				}
				document.documentElement.style.fontSize = `${scale * 100}%`;
			}

			// 立即执行一次
			adjustPageScale();

			// 监听窗口大小变化
			window.addEventListener("resize", adjustPageScale);

			// Swup 页面切换后也需要检查
			document.addEventListener("swup:page:view", adjustPageScale);
			window.addEventListener("orientationchange", adjustPageScale);
		}
	})();
</script>

<!-- Dev mode script - avoid swup replacing head styles -->
<script is:inline define:vars={{ IS_DEV: import.meta.env.DEV }}>
	// Dev 模式下，避免 swup 在页面切换时反复替换 head 中的样式标签，导致偶发样式丢失
	if (IS_DEV) {
		document.addEventListener("swup:enable", () => {
			if (window?.swup?.options) {
				window.swup.options.updateHead = false;
			}
		});
		if (window?.swup?.options) {
			window.swup.options.updateHead = false;
		}
	}
</script>
