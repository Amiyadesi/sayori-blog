---
import { Icon } from "astro-icon/components";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";

interface Props {
	id: string;
	name?: string;
	isCollapsed?: boolean;
	collapsedHeight?: string;
	class?: string;
	style?: string;
}
const { id, name, isCollapsed, collapsedHeight, style } = Astro.props;
const className = Astro.props.class;
const widgetShellClass = [
	"paper-note",
	"paper-note-lined",
	"paper-note-taped",
	"paper-tape",
	"paper-list-item",
	"pb-4",
	"pt-4",
	"card-base",
	className || "",
].join(" ");
---

<widget-layout
	data-id={id}
	data-is-collapsed={String(isCollapsed)}
	data-paper-tear="widget"
	class={widgetShellClass}
	style={style}
>
	{
		name && (
			<div class="paper-title font-bold transition text-lg text-neutral-900 dark:text-neutral-100 relative ml-7 mt-3 mb-2 flex items-center gap-2 pr-10">
				<button
					type="button"
					class="widget-tear-trigger absolute right-1 top-1/2"
					data-paper-tear-trigger
					aria-label="撕掉这张纸条"
					title="撕掉这张纸条"
				>
					<Icon
						name="material-symbols:content-cut-rounded"
						class="text-base"
						aria-hidden="true"
					/>
				</button>
				<span
					class="inline-block h-4 w-1 rounded-md bg-[var(--primary)]"
					aria-hidden="true"
				/>
				{name}
				<slot name="title-icon" />
			</div>
		)
	}
	<div
		id={id}
		class:list={[
			"collapse-wrapper px-4 overflow-hidden",
			{ collapsed: isCollapsed },
		]}
	>
		<slot />
	</div>
	{
		isCollapsed && (
			<div class="expand-btn px-4 -mb-2">
				<button class="btn-plain rounded-lg w-full h-9">
					<div class="text-[var(--primary)] flex items-center justify-center gap-2 -translate-x-2">
						<Icon
							name="material-symbols:more-horiz"
							class="text-[1.75rem]"
						/>{" "}
						{i18n(I18nKey.more)}
					</div>
				</button>
			</div>
		)
	}
</widget-layout>

<style define:vars={{ collapsedHeight }}>
	.collapsed {
		height: var(--collapsedHeight);
	}

	.widget-tear-trigger[data-paper-tear-trigger] {
		display: inline-flex;
		width: 1.75rem;
		height: 1.75rem;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: 1px dashed
			color-mix(in srgb, var(--paper-muted) 42%, transparent);
		border-radius: 9999px;
		background: color-mix(in srgb, var(--paper-bg) 84%, var(--primary) 8%);
		box-shadow: 0 2px 8px
			color-mix(in srgb, var(--paper-muted) 18%, transparent);
		color: var(--paper-muted);
		transform: translateY(-50%) rotate(-6deg);
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			background-color 160ms ease,
			color 160ms ease,
			box-shadow 160ms ease;
	}

	.widget-tear-trigger[data-paper-tear-trigger]:hover {
		border-color: color-mix(in srgb, var(--primary) 48%, transparent);
		background: color-mix(in srgb, var(--paper-bg) 72%, var(--primary) 14%);
		color: var(--primary);
		transform: translateY(-50%) rotate(-12deg) scale(1.06);
	}

	.widget-tear-trigger[data-paper-tear-trigger]:active {
		transform: translateY(-50%) rotate(-8deg) scale(0.96);
	}

	.widget-tear-trigger[data-paper-tear-trigger]:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--primary) 72%, white);
		outline-offset: 2px;
		color: var(--primary);
	}
</style>

<script>
	class WidgetLayout extends HTMLElement {
		constructor() {
			super();

			if (this.dataset.isCollapsed !== "true") {
				return;
			}

			const id = this.dataset.id;
			const btn = this.querySelector(".expand-btn");
			const wrapper = this.querySelector(`#${id}`);
			btn!.addEventListener("click", () => {
				wrapper!.classList.remove("collapsed");
				btn!.classList.add("hidden");
			});
		}
	}

	if (!customElements.get("widget-layout")) {
		customElements.define("widget-layout", WidgetLayout);
	}
</script>
