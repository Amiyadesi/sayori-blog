---
import { Icon } from "astro-icon/components";

import { announcementConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import WidgetLayout from "../common/WidgetLayout.astro";

const config = announcementConfig;
const announcementId = config.id || "default";

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<!-- 组件显示现在由sidebarLayoutConfig统一控制，无需检查config.enable -->
<WidgetLayout
	name={config.title || i18n(I18nKey.announcement)}
	id="announcement"
	class={className}
	style={style}
>
	<div data-announcement-widget data-announcement-id={announcementId}>
		<!-- 公告栏内容 -->
		<div
			class="text-neutral-600 dark:text-neutral-300 leading-relaxed mb-3"
		>
			{config.content}
		</div>

		<!-- 可选链接和关闭按钮 -->
		<div class="flex items-center justify-between gap-3">
			<div>
				{
					config.link && config.link.enable !== false && (
						<a
							href={config.link.url}
							target={config.link.external ? "_blank" : "_self"}
							rel={
								config.link.external
									? "noopener noreferrer"
									: undefined
							}
							class="btn-regular rounded-lg px-3 py-1.5 text-sm font-medium active:scale-95 transition-transform"
						>
							{config.link.text}
						</a>
					)
				}
			</div>

			{
				config.closable && (
					<button
						class="btn-regular rounded-lg h-8 w-8 text-sm hover:bg-red-100 dark:hover:bg-red-900/30 transition-colors"
						data-announcement-sidebar-close
						aria-label={i18n(I18nKey.announcementClose)}
					>
						<Icon name="fa7-solid:xmark" class="text-sm" />
					</button>
				)
			}
		</div>
	</div>
</WidgetLayout>

<script>
	const ANNOUNCEMENT_READ_KEY = "sayori-announcement-read-id";
	const LEGACY_CLOSED_KEY = "announcementClosed";

	function getCurrentAnnouncementId() {
		const widget = document.querySelector("[data-announcement-widget]");
		return widget?.getAttribute("data-announcement-id") || "default";
	}

	function readStoredAnnouncementId() {
		try {
			return localStorage.getItem(ANNOUNCEMENT_READ_KEY) || "";
		} catch {
			return window.__sayoriAnnouncementSessionReadId || "";
		}
	}

	function writeStoredAnnouncementId() {
		const currentAnnouncementId = getCurrentAnnouncementId();
		window.__sayoriAnnouncementSessionReadId = currentAnnouncementId;
		try {
			localStorage.setItem(
				ANNOUNCEMENT_READ_KEY,
				currentAnnouncementId,
			);
			localStorage.removeItem(LEGACY_CLOSED_KEY);
		} catch {
			// Storage may be blocked; keep the sidebar hidden for this session.
		}
	}

	function markAnnouncementRead() {
		writeStoredAnnouncementId();
		const currentAnnouncementId = getCurrentAnnouncementId();
		document.dispatchEvent(
			new CustomEvent("sayori:announcement-state", {
				detail: { id: currentAnnouncementId, unread: false },
			}),
		);
	}

	function hideAnnouncementWidgets() {
		// 通过data-id属性找到整个widget-layout元素
		const widgetLayouts = document.querySelectorAll(
			'widget-layout[data-id="announcement"]',
		);
		if (widgetLayouts.length > 0) {
			widgetLayouts.forEach((widget) => {
				// 隐藏整个widget-layout元素
				(widget as HTMLElement).style.display = "none";
			});
		}
	}

	function closeAnnouncement() {
		hideAnnouncementWidgets();
		markAnnouncementRead();
	}

	function syncAnnouncementVisibility() {
		const widgetLayouts = document.querySelectorAll(
			'widget-layout[data-id="announcement"]',
		);

		let isRead = readStoredAnnouncementId() === getCurrentAnnouncementId();
		try {
			if (!isRead && localStorage.getItem(LEGACY_CLOSED_KEY) === "true") {
				markAnnouncementRead();
				isRead = true;
			}
		} catch {
			// Ignore blocked storage.
		}

		if (widgetLayouts.length > 0 && isRead) {
			widgetLayouts.forEach((widget) => {
				(widget as HTMLElement).style.display = "none";
			});
		}
	}

	function bindAnnouncementCloseButtons() {
		document
			.querySelectorAll("[data-announcement-sidebar-close]")
			.forEach((button) => {
				if ((button as HTMLElement).dataset.bound === "true") {
					return;
				}
				(button as HTMLElement).dataset.bound = "true";
				button.addEventListener("click", closeAnnouncement);
			});
	}

	// 页面加载时检查是否已关闭
	document.addEventListener("DOMContentLoaded", function () {
		bindAnnouncementCloseButtons();
		syncAnnouncementVisibility();
	});
	document.addEventListener("mizuki:page:loaded", function () {
		bindAnnouncementCloseButtons();
		syncAnnouncementVisibility();
	});
	document.addEventListener(
		"sayori:announcement-state",
		syncAnnouncementVisibility,
	);

	// 使公告栏函数全局可用
	window.closeAnnouncement = closeAnnouncement;
</script>
