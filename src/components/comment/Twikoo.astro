	:global(.tk-owner-comment) {
		border-color: color-mix(in srgb, var(--primary) 26%, transparent);
	}

	:global(.tk-owner-avatar img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
