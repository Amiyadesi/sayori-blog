		color: rgba(0, 0, 0, 0.56);
	}

	.twikoo-loading,
	.twikoo-unavailable {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 1.25rem 1.5rem;
		border: 1px solid var(--paper-edge);
		border-radius: var(--paper-radius);
		color: var(--paper-muted);
		background:
			var(--paper-overlay),
			var(--paper-line-image),
			var(--paper-bg-soft);
		background-position: 0 0, 0 var(--paper-line-offset), 0 0;
		box-shadow: var(--paper-shadow-flat);
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.twikoo-loading,
	.twikoo-unavailable {
		flex-direction: column;
		align-items: flex-start;
		justify-content: flex-start;
	}

	.twikoo-loading span,
	.twikoo-unavailable span {
		font-size: 0.875rem;
		opacity: 0.75;
	}

	:global(.dark) .twikoo-loading,
	:global(.dark) .twikoo-unavailable {
		color: var(--paper-muted);
		background:
			var(--paper-overlay),
			var(--paper-line-image),
			var(--paper-bg-soft);
		border-color: var(--paper-edge);
	}

	:global(.dark) .twikoo-review-hint {
		color: rgba(255, 255, 255, 0.62);
	}

	:global(.is-review-only .tk-comments-container),
	:global(.is-review-only .tk-expand-wrap),
	:global(.is-review-only .tk-collapse-wrap) {
		display: none !important;
	}

	:global(.is-review-only .tk-submit-review-only) {
