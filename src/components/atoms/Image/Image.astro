---
import path from "node:path";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	loading?: "eager" | "lazy";
	fetchpriority?: "high" | "low" | "auto";
	widths?: number[];
	sizes?: string;
	width?: number;
	height?: number;
}

import { Image as AstroImage } from "astro:assets";

import { resolveLocalImage } from "@utils/local-image";
import { url } from "../../../utils/url-utils";

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	loading = "lazy",
	fetchpriority,
	widths,
	sizes,
	width,
	height,
} = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
// biome-ignore lint/suspicious/noImplicitAnyLet: <check later>
let img: ImageMetadata | undefined;
if (isLocal) {
	img = await resolveLocalImage(basePath, src);
	if (!img) {
		console.error(
			`\n[ERROR] Image file not found: ${path.normalize(path.join("src", basePath, src)).replace(/\\/g, "/")}`,
		);
	}
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;

// 检查是否是 Bilibili 图片
const isBilibiliImage = !isLocal && src.includes("hdslb.com");
// 对于外部图片（特别是 Bilibili），需要设置 referrerpolicy 避免 403 错误
const referrerPolicy = !isLocal && isBilibiliImage ? "no-referrer" : undefined;
---

<div id={id} class:list={[className, "overflow-hidden relative"]}>
	<div
		class="transition absolute inset-0 dark:bg-black/10 bg-opacity-50 pointer-events-none"
	>
	</div>
	{
		isLocal && img && (
			<AstroImage
				src={img}
				alt={alt || ""}
				class={imageClass}
				style={imageStyle}
				loading={loading}
				fetchpriority={fetchpriority}
				widths={widths}
				sizes={sizes}
				width={width}
				height={height}
			/>
		)
	}
	{
		!isLocal && (
			<img
				src={isPublic ? url(src) : src}
				alt={alt || ""}
				class={imageClass}
				style={imageStyle}
				loading={loading}
				width={width}
				height={height}
				referrerpolicy={referrerPolicy}
				crossorigin={isBilibiliImage ? "anonymous" : undefined}
				fetchpriority={fetchpriority}
			/>
		)
	}
</div>
