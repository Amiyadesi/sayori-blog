---
import SharePoster from "@components/misc/SharePoster.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { Icon } from "astro-icon/components";

import { profileConfig } from "../../../config";
import { formatDateToYYYYMMDD } from "../../../utils/date-utils";
import { getTagUrl } from "../../../utils/url-utils";

interface Props {
	path: string;
	title: string;
	description?: string;
	author?: string;
	pubDate: string;
	coverImage?: string;
	url: string;
	siteTitle: string;
	avatar?: string;
	tags?: string[];
	lastEditedDate: Date;
	class?: string;
}

const {
	path,
	title,
	description = "",
	author = profileConfig.name,
	pubDate,
	coverImage,
	url,
	siteTitle,
	avatar,
	tags = [],
	lastEditedDate,
	class: className = "",
} = Astro.props;

const finalAuthor = author || profileConfig.name;
const growthUrl = `/admin/growth/?post=${encodeURIComponent(path)}`;
---

<section
	id="share-component"
	class:list={[
		"post-engagement onload-animation mt-8 pt-6 border-t border-dashed border-[var(--line-divider)]",
		className,
	]}
	data-post-engagement
	data-path={path}
	data-url={url}
	data-title={title}
	data-like-text={i18n(I18nKey.postLike)}
	data-liked-text={i18n(I18nKey.postLiked)}
	data-copy-failed-text={i18n(I18nKey.postCopyFailedManual)}
	data-stats-failed-text={i18n(I18nKey.postInteractionFailed)}
>
	<div class="post-engagement-grid">
		<div class="post-engagement-primary">
			<div class="post-engagement-primary-header">
				<div class="post-engagement-icon">
					<Icon name="material-symbols:local-cafe-outline-rounded" />
				</div>
				<div>
					<div class="post-engagement-title">{i18n(I18nKey.postReward)}</div>
					<div class="post-engagement-count" data-reward-count>0</div>
				</div>
			</div>
			<div class="post-engagement-links">
				<a href="/sponsor/" data-post-action="reward" data-post-target="sponsor">
					{i18n(I18nKey.postReward)}
				</a>
			</div>
		</div>

		<button
			type="button"
			class="post-engagement-primary post-like-button"
			data-post-action="like"
			data-post-target="like"
			aria-pressed="false"
		>
			<div class="post-engagement-primary-header">
				<div class="post-engagement-icon">
					<Icon name="material-symbols:favorite-outline-rounded" />
				</div>
				<div>
					<div class="post-engagement-title" data-like-label>
						{i18n(I18nKey.postLike)}
					</div>
					<div class="post-engagement-count" data-like-count>0</div>
				</div>
			</div>
		</button>

		<div class="post-engagement-primary post-share-actions">
			<div class="post-engagement-primary-header">
				<div class="post-engagement-icon">
					<Icon name="material-symbols:ios-share-rounded" />
				</div>
				<div class="post-engagement-title">{i18n(I18nKey.postShare)}</div>
			</div>
			<div class="post-engagement-links">
				<button type="button" data-copy-share>
					<Icon name="material-symbols:link-rounded" />
					<span>{i18n(I18nKey.copyLink)}</span>
				</button>
				<button type="button" data-native-share hidden>
					<Icon name="material-symbols:ios-share-rounded" />
					<span>{i18n(I18nKey.postNativeShare)}</span>
				</button>
				<div class="post-poster-share">
					<SharePoster
						client:visible
						{title}
						author={finalAuthor}
						description={description}
						{pubDate}
						coverImage={coverImage ?? null}
						{url}
						{siteTitle}
						avatar={avatar ?? null}
						buttonLabel={i18n(I18nKey.postGeneratePoster)}
					/>
				</div>
			</div>
		</div>
	</div>

	<div class="post-copy-fallback" data-copy-fallback hidden>
		<label>
			<span>{i18n(I18nKey.postCopyFallbackLabel)}</span>
			<input type="text" readonly value={url} data-copy-fallback-input />
		</label>
	</div>

	<div class="post-engagement-footer">
		<div class="post-engagement-tags" aria-label={i18n(I18nKey.tags)}>
			{
				tags.length > 0 ? (
					tags.map((tag) => (
						<a href={getTagUrl(tag)}>
							<span>#</span>
							{tag.trim()}
						</a>
					))
				) : (
					<span>{i18n(I18nKey.noTags)}</span>
				)
			}
		</div>
		<div class="post-engagement-meta">
			<a class="post-promote-link" href={growthUrl} data-promote-post hidden>
				<Icon name="material-symbols:monitoring-rounded" />
				<span>{i18n(I18nKey.postPromote)}</span>
			</a>
			<div class="post-last-edited">
				<Icon name="material-symbols:edit-calendar-outline-rounded" />
				<span>
					{i18n(I18nKey.postLastEdited)} {formatDateToYYYYMMDD(lastEditedDate)}
				</span>
			</div>
		</div>
	</div>
	<p class="post-engagement-status" data-engagement-status aria-live="polite" hidden></p>
</section>

<script>
	import { initPostEngagement } from "@/scripts/post-engagement";

	initPostEngagement();
	document.addEventListener("swup:pageView", initPostEngagement);
</script>

<style>
	.post-engagement { color: rgba(0, 0, 0, 0.72); }
	:global(.dark) .post-engagement { color: rgba(255, 255, 255, 0.72); }

	.post-engagement-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.post-engagement-primary {
		display: flex;
		min-height: 6.4rem;
		flex-direction: column;
		justify-content: space-between;
		gap: 1rem;
		border: 1px solid rgba(0, 0, 0, 0.08);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.46);
		padding: 1rem;
		text-align: left;
		transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}

	button.post-engagement-primary { cursor: pointer; }
	.post-engagement-primary:hover {
		transform: translateY(-1px);
		border-color: color-mix(in srgb, var(--primary) 30%, transparent);
		background: rgba(255, 255, 255, 0.68);
	}
	:global(.dark) .post-engagement-primary {
		border-color: rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.045);
	}

	.post-engagement-primary-header,
	.post-engagement-meta,
	.post-last-edited,
	.post-promote-link {
		display: flex;
		align-items: center;
		gap: 0.55rem;
	}

	.post-engagement-icon {
		display: flex;
		height: 2.65rem;
		width: 2.65rem;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		border-radius: 8px;
		background: color-mix(in srgb, var(--primary) 14%, transparent);
		color: var(--primary);
		font-size: 1.55rem;
	}

	.post-engagement-title {
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.35;
		color: rgba(0, 0, 0, 0.78);
	}
	:global(.dark) .post-engagement-title { color: rgba(255, 255, 255, 0.82); }

	.post-engagement-count {
		margin-top: 0.15rem;
		font-size: 0.82rem;
		color: rgba(0, 0, 0, 0.46);
	}

	.post-engagement-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.post-engagement-links a,
	.post-engagement-links button,
	:global(.post-poster-share > button),
	.post-promote-link {
		display: inline-flex;
		min-height: 2.2rem;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		border-radius: 8px;
		background: rgba(0, 0, 0, 0.055);
		padding: 0.42rem 0.7rem;
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1;
		color: rgba(0, 0, 0, 0.62);
		transition: background 0.2s ease, color 0.2s ease;
	}

	.post-engagement-links a:hover,
	.post-engagement-links button:hover,
	:global(.post-poster-share > button:hover),
	.post-promote-link:hover,
	.post-like-button.is-liked {
		background: color-mix(in srgb, var(--primary) 18%, transparent);
		color: var(--primary);
	}

	:global(.dark) .post-engagement-links a,
	:global(.dark) .post-engagement-links button,
	:global(.dark .post-poster-share > button),
	:global(.dark) .post-promote-link {
		background: rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.7);
	}

	.post-copy-fallback {
		margin-top: 0.85rem;
		padding: 0.8rem;
		border: 1px solid color-mix(in srgb, var(--primary) 35%, transparent);
		border-radius: 8px;
		background: color-mix(in srgb, var(--card-bg) 92%, transparent);
	}
	.post-copy-fallback label { display: grid; gap: 0.45rem; font-size: 0.8rem; font-weight: 700; }
	.post-copy-fallback input {
		width: 100%;
		border: 1px solid var(--line-divider);
		border-radius: 6px;
		background: var(--card-bg);
		padding: 0.65rem;
		color: var(--text-90);
	}

	.post-engagement-footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.85rem;
		margin-top: 1rem;
	}

	.post-engagement-tags { display: flex; flex-wrap: wrap; gap: 0.45rem; }
	.post-engagement-tags a,
	.post-engagement-tags > span {
		display: inline-flex;
		align-items: center;
		gap: 0.16rem;
		border-radius: 8px;
		background: rgba(0, 0, 0, 0.055);
		padding: 0.36rem 0.68rem;
		font-size: 0.78rem;
		font-weight: 700;
		color: rgba(0, 0, 0, 0.52);
	}
	:global(.dark) .post-engagement-tags a,
	:global(.dark) .post-engagement-tags > span { background: rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.64); }

	.post-engagement-meta { flex-wrap: wrap; justify-content: flex-end; }
	.post-last-edited { font-size: 0.82rem; font-weight: 700; color: rgba(0, 0, 0, 0.48); }
	:global(.dark) .post-last-edited { color: rgba(255, 255, 255, 0.54); }

	.post-engagement-status { margin-top: 0.7rem; font-size: 0.78rem; color: #b42318; }

	@media (max-width: 767px) {
		.post-engagement-grid { grid-template-columns: 1fr; }
		.post-engagement-primary { min-height: 5.6rem; }
		.post-engagement-footer { align-items: flex-start; flex-direction: column; }
		.post-engagement-meta { justify-content: flex-start; }
	}
</style>
